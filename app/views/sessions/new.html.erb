<h1>Login</h1>

<%= form_with url: "/sessions", method: :post, local: true do %>
  <p>
    <%= label_tag :email, "Email", for: "email_input" %>
    <%= text_field_tag :email, nil, id: "email_input" %>

    <%= label_tag :password, "Password", for: "password_input" %>
    <%= password_field_tag :password, nil, id: "password_input" %>
  </p>

  <%= button_tag "Login" %>
<% end %>

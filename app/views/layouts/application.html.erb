<!DOCTYPE html>
<html>
  <head>
    <title>Travel Journal</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/application.css">
  </head>

  <body>
    <nav class="navbar navbar-dark bg-dark px-3">
      <a href="/places" class="navbar-brand">Travel Journal</a>
      <div class="navbar-nav ms-auto">
        <% if @current_user %>
          <span class="nav-link text-white"><%= @current_user["username"] %></span>
          <%= button_to "Logout", "/logout", method: :delete, class: "btn btn-link nav-link" %>
        <% else %>
          <a href="/login" class="nav-link">Login</a>
          <a href="/users/new" class="nav-link">Signup</a>
        <% end %>
      </div>
    </nav>

    <div class="container mt-4">
      <%= flash["notice"] %>
      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
